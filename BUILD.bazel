        '--clang-arg=-DGENTEST_CODEGEN=1 ' +
        '--clang-arg=-DFMT_HEADER_ONLY ' +
        '--clang-arg=-Wno-unknown-attributes ' +
        '--clang-arg=-Wno-attributes ' +
        '--clang-arg=-Wno-unknown-warning-option ' +
        '--clang-arg=-Iinclude ' +
        '--clang-arg=-Itests ' +
        '--clang-arg=-Ithird_party/include'
