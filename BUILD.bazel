_gentest_linkopts = select({
    '@bazel_tools//src/conditions:windows': [],
    '@bazel_tools//src/conditions:darwin': [],
    '//conditions:default': ['-fuse-ld=bfd'],
})

# Build gentest_codegen via CMake inside Bazel
_gentest_codegen_build_srcs = glob(
    [
        "CMakeLists.txt",
        "cmake/**",
        "tools/**",
        "include/**",
        "vcpkg.json",
        "vcpkg-configuration.json",
    ],
    exclude = [
        "build/**",
        "bazel-*/**",
        ".git/**",
    ],
    allow_empty = False,
)

genrule(
    name = 'gentest_codegen_build_unix',
    # Best-effort dependency tracking: this genrule shells out to CMake and is not hermetic.
    # Still, we want Bazel to rebuild `gentest_codegen` when the generator sources/config change.
    srcs = _gentest_codegen_build_srcs,
    outs = ['gen_tools/gentest_codegen'],
    cmd = "set -e; " +
          "GENTEST_CMAKE_ARGS='-DCMAKE_BUILD_TYPE=Release -DCMAKE_EXPORT_COMPILE_COMMANDS=ON'; " +
          "if [ -x /opt/homebrew/bin/cmake ]; then GENTEST_CMAKE_BIN=/opt/homebrew/bin/cmake; " +
          "else GENTEST_CMAKE_BIN=$$(command -v cmake); fi && " +
          "if [ -x /opt/homebrew/bin/ninja ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -G Ninja -DCMAKE_MAKE_PROGRAM=/opt/homebrew/bin/ninja\"; fi && " +
          "if [ -n \"$${CC:-}\" ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DCMAKE_C_COMPILER=$$CC\"; " +
          "elif [ -x /opt/homebrew/opt/llvm/bin/clang ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DCMAKE_C_COMPILER=/opt/homebrew/opt/llvm/bin/clang\"; fi && " +
          "if [ -n \"$${CXX:-}\" ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DCMAKE_CXX_COMPILER=$$CXX\"; " +
          "elif [ -x /opt/homebrew/opt/llvm/bin/clang++ ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DCMAKE_CXX_COMPILER=/opt/homebrew/opt/llvm/bin/clang++\"; fi && " +
          "if [ -n \"$${LLVM_DIR:-}\" ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DLLVM_DIR=$$LLVM_DIR\"; " +
          "elif [ -d /opt/homebrew/opt/llvm/lib/cmake/llvm ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DLLVM_DIR=/opt/homebrew/opt/llvm/lib/cmake/llvm\"; fi && " +
          "if [ -n \"$${Clang_DIR:-}\" ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DClang_DIR=$$Clang_DIR\"; " +
          "elif [ -d /opt/homebrew/opt/llvm/lib/cmake/clang ]; then GENTEST_CMAKE_ARGS=\"$$GENTEST_CMAKE_ARGS -DClang_DIR=/opt/homebrew/opt/llvm/lib/cmake/clang\"; fi && " +
          "if [ -z \"$${GENTEST_CMAKE_BIN}\" ]; then echo 'gentest bazel: cmake not found' >&2; exit 127; fi && " +
          "rm -rf $(@D)/b && mkdir -p $(@D)/b && " +
          "\"$${GENTEST_CMAKE_BIN}\" -S . -B $(@D)/b $$GENTEST_CMAKE_ARGS && " +
          "\"$${GENTEST_CMAKE_BIN}\" --build $(@D)/b --target gentest_codegen -j 1 && " +
          "if [ -f $(@D)/b/compile_commands.json ]; then cp $(@D)/b/compile_commands.json $(@D)/compile_commands.json; fi && " +
          "cp $(@D)/b/tools/gentest_codegen $@",
    tags = ['no-sandbox', 'local'],
    target_compatible_with = select({
        '@bazel_tools//src/conditions:windows': ['@platforms//:incompatible'],
        '//conditions:default': [],
    }),
)

genrule(
    name = 'gentest_codegen_build_windows',
    srcs = _gentest_codegen_build_srcs,
    outs = ['gen_tools/gentest_codegen.exe'],
    cmd_bat = "set GENTEST_CMAKE_ARGS=-DCMAKE_BUILD_TYPE=Release -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && " +
              "if defined CC set GENTEST_CMAKE_ARGS=%GENTEST_CMAKE_ARGS% -DCMAKE_C_COMPILER=\"%CC%\" && " +
              "if defined CXX set GENTEST_CMAKE_ARGS=%GENTEST_CMAKE_ARGS% -DCMAKE_CXX_COMPILER=\"%CXX%\" && " +
              "if defined LLVM_DIR set GENTEST_CMAKE_ARGS=%GENTEST_CMAKE_ARGS% -DLLVM_DIR=\"%LLVM_DIR%\" && " +
              "if defined Clang_DIR set GENTEST_CMAKE_ARGS=%GENTEST_CMAKE_ARGS% -DClang_DIR=\"%Clang_DIR%\" && " +
              "if exist \"%ProgramFiles%\\CMake\\bin\\cmake.exe\" (set GENTEST_CMAKE_BIN=%ProgramFiles%\\CMake\\bin\\cmake.exe) else (set GENTEST_CMAKE_BIN=cmake) && " +
              "if exist $(@D)\\b rmdir /S /Q $(@D)\\b && mkdir $(@D)\\b && " +
              "\"%GENTEST_CMAKE_BIN%\" -S . -B $(@D)\\b %GENTEST_CMAKE_ARGS% && " +
              "\"%GENTEST_CMAKE_BIN%\" --build $(@D)\\b --target gentest_codegen --config Release && " +
              "if exist $(@D)\\b\\compile_commands.json copy /Y $(@D)\\b\\compile_commands.json $(@D)\\compile_commands.json >NUL && " +
              "(if exist $(@D)\\b\\tools\\Release\\gentest_codegen.exe " +
              "(copy /Y $(@D)\\b\\tools\\Release\\gentest_codegen.exe $@ >NUL) " +
              "else (copy /Y $(@D)\\b\\tools\\gentest_codegen.exe $@ >NUL))",
    tags = ['no-sandbox', 'local'],
    target_compatible_with = select({
        '@bazel_tools//src/conditions:windows': [],
        '//conditions:default': ['@platforms//:incompatible'],
    }),
)

alias(
    name = 'gentest_codegen_build',
    actual = select({
        '@bazel_tools//src/conditions:windows': ':gentest_codegen_build_windows',
        '//conditions:default': ':gentest_codegen_build_unix',
    }),
)

alias(
    name = 'gentest_codegen',
    actual = ':gentest_codegen_build',
    visibility = ['//visibility:public'],
)

