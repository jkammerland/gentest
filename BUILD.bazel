        '--mock-impl "$(@D)/gen/consumer_textual_mocks/consumer_textual_mocks_mock_impl.hpp" ' +
        '--target-id consumer_textual_mocks ' +
        '--defs-file tests/consumer/header_mock_defs.hpp ' +
        '--include-root include ' +
        '--include-root tests ' +
        '--include-root third_party/include ' +
        '--clang-arg=-std=c++20 ' +
        '--clang-arg=-DGENTEST_CODEGEN=1 ' +
        '--clang-arg=-DFMT_HEADER_ONLY ' +
        '--clang-arg=-Wno-unknown-attributes ' +
