        "if not exist $(@D)\\gen\\consumer_textual_mocks mkdir $(@D)\\gen\\consumer_textual_mocks && " +
        'python "$(location scripts/gentest_buildsystem_codegen.py)" ' +
        '--backend bazel ' +
        '--mode mocks ' +
        '--kind textual ' +
        '--codegen "$(location :gentest_codegen)" ' +
        '--source-root . ' +
        '--out-dir "$(@D)/gen/consumer_textual_mocks" ' +
        '--wrapper-output "$(@D)/gen/consumer_textual_mocks/consumer_textual_mocks_defs.cpp" ' +
